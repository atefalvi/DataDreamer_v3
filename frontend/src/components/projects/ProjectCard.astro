---
/**
 * ProjectCard — Reusable card component for the projects grid.
 * Images default to grayscale, color on hover with smooth transition.
 */
interface Props {
    title: string;
    description: string;
    image: string;
    index: string;
    year: string;
    tags: string[];
    href?: string;
}

const { title, description, image, index, year, tags, href = '#' } = Astro.props;
---

<a href={href} class="project-card">
    <div class="project-thumb-wrap">
        <img src={image} alt={title} loading="lazy" />
    </div>
    <div class="project-meta-top">
        <span>{index}</span>
        <span>{year}</span>
    </div>
    <h2 class="project-card-title">{title}</h2>
    <p class="project-card-desc">{description}</p>
    <div class="project-card-tags">
        {tags.map(tag => <span class="mini-tag">{tag}</span>)}
    </div>
</a>

<style>
    .project-card {
        display: flex;
        flex-direction: column;
        text-decoration: none;
        color: inherit;
        transition: transform 0.3s ease;
    }

    .project-card:hover .project-thumb-wrap img {
        transform: scale(1.05);
        filter: grayscale(0%);
    }

    .project-thumb-wrap {
        width: 100%;
        aspect-ratio: 4/3;
        background: #eee;
        overflow: hidden;
        margin-bottom: 20px;
        position: relative;
    }

    .project-thumb-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: grayscale(100%) contrast(110%);
        transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .project-meta-top {
        display: flex;
        justify-content: space-between;
        font-size: 10px;
        color: var(--color-primary);
        font-weight: 700;
        margin-bottom: 8px;
    }

    .project-card-title {
        font-family: var(--font-display);
        font-size: 32px;
        line-height: 1;
        margin-bottom: 12px;
        text-transform: uppercase;
    }

    .project-card-desc {
        font-size: 12px;
        line-height: 1.6;
        color: #666;
        margin-bottom: 16px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .project-card-tags {
        display: flex;
        gap: 8px;
        margin-top: auto;
    }

    .mini-tag {
        font-size: 9px;
        padding: 2px 6px;
        border: 1px solid #e5e5e5;
        color: #999;
        text-transform: uppercase;
    }

    @media (prefers-color-scheme: dark) {
        .project-thumb-wrap { background: #1a1a1a; }
        .project-card-desc { color: #aaa; }
        .mini-tag { border-color: #333; color: #666; }
    }
</style>
