---
/**
 * QuoteBlock — Pull-quote styled block matching reference/blog.html.
 */
interface Props {
    text: string;
}

const { text } = Astro.props;
---

<div class="pull-quote" set:html={text} />

<style>
    .pull-quote {
        font-family: var(--font-display);
        font-size: 32px;
        color: var(--color-primary);
        margin: 48px 0;
        line-height: 1.1;
        padding: 32px;
        background: var(--accent-soft);
        border-right: 8px solid var(--color-primary);
        text-transform: uppercase;
    }

    @media (max-width: 768px) {
        .pull-quote { font-size: 24px; padding: 24px; }
    }
</style>
