---
/**
 * RelatedLogs — Shows related blog posts, excluding the current one.
 * Matches the reference/blog.html related-section styling.
 */
interface Post {
    slug: string;
    title: string;
    summary?: string;
}

interface Props {
    currentSlug: string;
    posts: Post[];
}

const { currentSlug, posts } = Astro.props;
const related = posts.filter(p => p.slug !== currentSlug).slice(0, 2);
---

{related.length > 0 && (
    <section class="related-section">
        <div class="related-inner">
            <div class="meta-text related-meta">// KEEP READING</div>
            <h2 class="section-title related-title-heading">RELATED LOGS</h2>
            <div class="related-grid">
                {related.map((post, i) => (
                    <a href={`/logs/${post.slug}`} class="related-card">
                        <div class="related-label">{i === 0 ? 'NEXT LOG' : 'PREVIOUS LOG'}</div>
                        <div class="related-title">{post.title}</div>
                        {post.summary && <p class="related-desc">{post.summary}</p>}
                    </a>
                ))}
            </div>
        </div>
    </section>
)}

<style>
    .related-meta {
        color: var(--text-secondary);
        margin-bottom: 8px;
    }

    .related-title-heading {
        margin-bottom: 0;
    }

    .related-section {
        background: var(--bg-muted);
        padding: 100px var(--container-padding);
        border-top: 1px solid var(--color-gray);
    }

    .related-inner {
        max-width: 1200px;
        margin: 0 auto;
    }

    .related-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1px;
        background: var(--color-gray);
        border: 1px solid var(--color-gray);
        margin-top: 40px;
    }

    .related-card {
        background: var(--bg-surface);
        padding: 40px;
        text-decoration: none;
        color: var(--text-primary);
        transition: background 0.2s;
    }

    .related-card:hover {
        background: var(--accent-soft);
    }

    .related-label {
        font-size: 10px;
        color: var(--text-secondary);
        text-transform: uppercase;
        margin-bottom: 8px;
        letter-spacing: 0.1em;
    }

    .related-title {
        font-family: var(--font-display);
        font-size: 28px;
        line-height: 1;
        margin: 12px 0;
        text-transform: uppercase;
    }

    .related-desc {
        font-size: 12px;
        color: var(--text-secondary);
        line-height: 1.6;
    }

    @media (max-width: 768px) {
        .related-grid { grid-template-columns: 1fr; }
        .related-card { padding: 28px 24px; }
    }
</style>
