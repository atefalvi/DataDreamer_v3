---
import { getAssetUrl } from "../../lib/directus";

interface Props {
    tagline?: string;
    title?: string;
    description?: string;
    imageFileId?: string;
    resumeId?: string;
}

const { 
    tagline = "// IDENTIFICATION: AI ENGINEER",
    title = "ATEF ALVI",
    description = "I build intelligent pipelines, agentic systems, and data-driven products that operate at the intersection of AI, infrastructure, and human impact.",
    imageFileId,
    resumeId
} = Astro.props;

const fallbackImage = "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=1000&auto=format&fit=crop";
const imageUrl = imageFileId ? getAssetUrl(imageFileId) : fallbackImage;
const resumeUrl = resumeId ? getAssetUrl(resumeId) : "#";

const titleWords = title.toUpperCase().split(" ");
---

<section class="about-hero" id="about">
    <div class="container">
        <div class="grid-12 about-grid">
            <!-- LEFT: Text Content -->
            <div class="hero-text-content">
                <div class="meta-label">{tagline}</div>
                <h1 class="hero-title">
                    {titleWords.map(word => <span class="word">{word}</span>)}
                </h1>
                <div class="hero-body">
                    <p class="readable-text">{description}</p>
                </div>
                <div class="hero-actions">
                    {resumeId && (
                        <a href={resumeUrl} class="btn-primary" target="_blank" rel="noopener">
                            ↓ DOWNLOAD RESUME
                        </a>
                    )}
                    <a href="/connect" class="btn-secondary">→ GET IN TOUCH</a>
                </div>
            </div>

            <!-- RIGHT: Canvas portrait with pixel disintegration -->
            <div class="hero-image-content">
                <div class="portrait-area">
                    <canvas id="portrait-canvas"></canvas>
                    <!-- Floating CSS pixel fragments -->
                    <div class="frag frag-1"></div>
                    <div class="frag frag-2"></div>
                    <div class="frag frag-3"></div>
                    <div class="frag frag-4"></div>
                    <div class="frag frag-5"></div>
                    <div class="frag frag-6"></div>
                    <div class="frag frag-7"></div>
                    <div class="frag frag-8"></div>
                    <div class="frag frag-9"></div>
                    <div class="frag frag-10"></div>
                    <div class="frag frag-11"></div>
                    <div class="frag frag-12"></div>
                </div>
            </div>
        </div>
    </div>
</section>

<script is:inline define:vars={{ imageUrl }}>
(function() {
    const canvas = document.getElementById('portrait-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');

    const img = new Image();
    img.crossOrigin = 'anonymous';

    img.onload = function() {
        const container = canvas.parentElement;
        const displayWidth = container.offsetWidth;
        const scale = displayWidth / img.naturalWidth;
        const displayHeight = img.naturalHeight * scale;

        const dpr = window.devicePixelRatio || 1;
        const padRight = 0;
        const padBottom = 10;
        canvas.width = (displayWidth + padRight) * dpr;
        canvas.height = (displayHeight + padBottom) * dpr;
        canvas.style.width = (displayWidth + padRight) + 'px';
        canvas.style.height = (displayHeight + padBottom) + 'px';
        ctx.scale(dpr, dpr);

        // Grayscale source
        const tempCanvas = document.createElement('canvas');
        tempCanvas.width = displayWidth * dpr;
        tempCanvas.height = displayHeight * dpr;
        const tempCtx = tempCanvas.getContext('2d');
        tempCtx.scale(dpr, dpr);
        tempCtx.filter = 'grayscale(100%) contrast(1.15) brightness(0.95)';
        tempCtx.drawImage(img, 0, 0, displayWidth, displayHeight);

        drawPixelDissolve(ctx, tempCanvas, displayWidth, displayHeight, dpr);
        drawEscapedBlocks(ctx, tempCanvas, displayWidth, displayHeight, dpr);
    };

    img.src = imageUrl;

    /**
     * Pixel Disintegration — clean bottom-fade with fixed 5px grid.
     * progress = max(0, (yRatio - 0.46) / 0.54)
     * Three tiers: solid, ghost, sparse.
     * Draw loop stops at 92% height.
     */
    function drawPixelDissolve(ctx, sourceCanvas, w, h, dpr) {
        let seed = 42;
        function seededRandom() {
            seed = (seed * 16807 + 0) % 2147483647;
            return (seed - 1) / 2147483646;
        }

        const B = 5;
        const cutoffY = h * 0.92;

        ctx.clearRect(0, 0, w + 50, h + 30);

        let y = 0;
        while (y < cutoffY) {
            const bh = Math.min(B, cutoffY - y);
            const yRatio = y / h;
            const progress = Math.max(0, (yRatio - 0.46) / 0.54);

            let x = 0;
            while (x < w) {
                const bw = Math.min(B, w - x);
                const roll = seededRandom();

                if (progress < 0.05) {
                    // Tier 1: solid face/head zone
                    ctx.globalAlpha = 1.0;
                    ctx.drawImage(
                        sourceCanvas,
                        x * dpr, y * dpr, bw * dpr, bh * dpr,
                        x, y, bw, bh
                    );
                } else if (progress < 0.7) {
                    // Tier 2: gradual thinning with ghost blocks
                    if (roll > progress) {
                        const alpha = Math.pow(1 - progress, 1.8);
                        ctx.globalAlpha = Math.max(0.15, Math.min(1.0, alpha));
                        ctx.drawImage(
                            sourceCanvas,
                            x * dpr, y * dpr, bw * dpr, bh * dpr,
                            x, y, bw, bh
                        );
                    }
                } else {
                    // Tier 3: very sparse, very faint
                    if (roll > Math.min(0.99, progress * 1.8)) {
                        const alpha = Math.pow(1 - progress, 3);
                        ctx.globalAlpha = Math.max(0.05, Math.min(0.3, alpha));
                        ctx.drawImage(
                            sourceCanvas,
                            x * dpr, y * dpr, bw * dpr, bh * dpr,
                            x, y, bw, bh
                        );
                    }
                }

                x += B;
            }
            y += B;
        }
        ctx.globalAlpha = 1.0;
    }

    /**
     * Escaped Fragments — 35 bold chunks breaking off the lower silhouette.
     * Clustered near lower-left and lower-right body edges.
     * Large sizes, high alpha, tight scatter radius.
     */
    function drawEscapedBlocks(ctx, sourceCanvas, w, h, dpr) {
        let seed2 = 137;
        function rng() {
            seed2 = (seed2 * 16807 + 0) % 2147483647;
            return (seed2 - 1) / 2147483646;
        }

        // Two origin clusters + far-flung outliers
        const origins = [
            { x: w * 0.72, y: h * 0.72, count: 18 },  // right edge breakup
            { x: w * 0.28, y: h * 0.74, count: 12 },  // left edge breakup
            { x: w * 0.65, y: h * 0.78, count: 8, far: true },  // far outliers, biased right
        ];

        const sizes = [6, 8, 10, 12, 14, 16, 18];

        for (const origin of origins) {
            for (let i = 0; i < origin.count; i++) {
                // Far outliers scatter 80–160px; close ones 15–90px
                const d = origin.far ? (80 + rng() * 80) : (15 + rng() * 75);
                // Fan outward from body edge
                // Far outliers get wider, more asymmetric angles
                const angleSpread = origin.far ? 1.2 : 0.8;
                const angle = (origin.x > w * 0.5)
                    ? -Math.PI * 0.3 + rng() * Math.PI * angleSpread
                    : Math.PI * 0.3 + rng() * Math.PI * angleSpread;

                // Larger blocks close, smaller far
                const bs = d < 40
                    ? sizes[Math.floor(rng() * 3) + 4]     // 14, 16, 18
                    : sizes[Math.floor(rng() * sizes.length)];

                // High alpha close, still readable far
                const alpha = d < 35
                    ? 0.5 + rng() * 0.2
                    : origin.far
                        ? Math.max(0.10, 0.40 - d / 300)
                        : Math.max(0.15, 0.55 - d / 200);

                // Sample from mid-body edge zones (higher contrast than dark hoodie bottom)
                const sx = (origin.x > w * 0.5)
                    ? w * 0.55 + rng() * w * 0.35   // right side of body
                    : w * 0.1 + rng() * w * 0.35;   // left side of body
                const sy = h * 0.4 + rng() * h * 0.3; // mid-torso, not bottom

                const rawPx = origin.x + Math.cos(angle) * d;
                const px = Math.min(rawPx, w + 40);
                const py = origin.y + Math.sin(angle) * d;

                ctx.globalAlpha = alpha;
                ctx.drawImage(
                    sourceCanvas,
                    sx * dpr, sy * dpr, bs * dpr, bs * dpr,
                    px, py, bs, bs
                );
            }
        }
        ctx.globalAlpha = 1.0;
    }
})();
</script>

<style>
    /* ─── HERO SHELL ──────────────────────────────────── */
    .about-hero {
        display: flex;
        align-items: center;
        padding: 140px 0 60px;
        min-height: auto;
        overflow: visible;
        background: var(--bg-primary);
        position: relative;
    }

    .about-hero .container {
        overflow: visible;
    }

    .about-grid {
        align-items: start;
        gap: 0;
    }

    .hero-text-content {
        grid-column: span 6;
        z-index: 2;
        padding-right: 40px;
    }

    .hero-image-content {
        grid-column: span 6;
        display: flex;
        justify-content: flex-start;
        align-items: flex-start;
        position: relative;
        overflow: visible;
    }



    /* ─── TYPOGRAPHY ────────────────────────────────── */
    .meta-label {
        font-family: var(--font-tech);
        font-size: 11px;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.15em;
        margin-bottom: 20px;
    }

    .hero-title {
        font-family: var(--font-display);
        font-size: clamp(80px, 10vw, 140px);
        line-height: 0.85;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .hero-title .word {
        display: block;
        color: var(--text-primary);
        transition: transform 0.4s var(--ease-out), color 0.2s;
        transform-origin: left;
    }

    .hero-title .word:hover {
        color: var(--accent);
        transform: skewX(-6deg) translateX(16px);
    }

    .hero-body {
        margin-top: 32px;
        padding-left: 24px;
        border-left: 1px solid var(--accent);
        max-width: 480px;
    }

    .readable-text {
        color: var(--text-primary);
        font-family: var(--font-tech);
        font-size: 16px;
        line-height: 1.7;
        opacity: 0.85;
    }

    /* ─── ACTIONS ───────────────────────────────────── */
    .hero-actions {
        display: flex;
        gap: 16px;
        margin-top: 48px;
    }

    .btn-primary, .btn-secondary {
        font-family: var(--font-tech);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        padding: 16px 32px;
        text-decoration: none;
        transition: all 0.3s var(--ease-out);
        border: 1px solid transparent;
        white-space: nowrap;
    }

    .btn-primary {
        background: var(--accent);
        color: #FFFFFF;
    }

    .btn-primary:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px var(--accent-soft);
        background: #D12500;
    }

    .btn-secondary {
        border-color: var(--border);
        color: var(--text-primary);
    }

    .btn-secondary:hover {
        background: var(--bg-muted);
        transform: translateY(-4px);
        border-color: var(--text-primary);
    }

    /* ─── PORTRAIT: CANVAS PIXEL DISSOLVE ────────────── */
    .portrait-area {
        position: relative;
        width: clamp(480px, 40vw, 640px);
        overflow: visible;
        transform: translate(-60px, -200px); /* Align with top-edge of first headline line */
        z-index: 1;
    }

    #portrait-canvas {
        display: block;
        width: 100%;
        height: auto;
    }

    /* ─── FLOATING CSS PIXEL FRAGMENTS ───────────────── */
    .frag {
        position: absolute;
        background: var(--text-primary);
        pointer-events: none;
        z-index: 3;
    }

    /* Right side — near the dissolve edge */
    .frag-1  { width: 6px;  height: 6px;  top: 58%; right: -8%;  opacity: 0.22; animation: frag-float 7s ease-in-out infinite; }
    .frag-2  { width: 4px;  height: 4px;  top: 65%; right: -14%; opacity: 0.14; animation: frag-float 9s ease-in-out infinite -2s; }
    .frag-3  { width: 8px;  height: 8px;  top: 72%; right: -5%;  opacity: 0.10; animation: frag-float 11s ease-in-out infinite -4s; }
    .frag-4  { width: 3px;  height: 3px;  top: 78%; right: -18%; opacity: 0.18; animation: frag-float 6s ease-in-out infinite -1s; }
    .frag-5  { width: 5px;  height: 5px;  top: 62%; right: -22%; opacity: 0.12; animation: frag-float 10s ease-in-out infinite -3s; }

    /* Bottom — just below the dissolve cutoff */
    .frag-6  { width: 7px;  height: 7px;  bottom: 8%;  left: 30%; opacity: 0.16; animation: frag-float 8s ease-in-out infinite -0.5s; }
    .frag-7  { width: 4px;  height: 4px;  bottom: 4%;  left: 45%; opacity: 0.20; animation: frag-float 7s ease-in-out infinite -2.5s; }
    .frag-8  { width: 6px;  height: 6px;  bottom: 2%;  left: 60%; opacity: 0.12; animation: frag-float 12s ease-in-out infinite -5s; }
    .frag-9  { width: 3px;  height: 3px;  bottom: 6%;  left: 70%; opacity: 0.22; animation: frag-float 9s ease-in-out infinite -1.5s; }

    /* Left edge — sparse */
    .frag-10 { width: 5px;  height: 5px;  top: 68%; left: -6%;  opacity: 0.10; animation: frag-float 10s ease-in-out infinite -3.5s; }
    .frag-11 { width: 3px;  height: 3px;  top: 75%; left: -10%; opacity: 0.14; animation: frag-float 8s ease-in-out infinite -4.5s; }
    .frag-12 { width: 4px;  height: 4px;  top: 82%; left: -3%;  opacity: 0.08; animation: frag-float 11s ease-in-out infinite -6s; }

    @keyframes frag-float {
        0%, 100% { transform: translate(0px, 0px); }
        25%       { transform: translate(3px, -8px); }
        50%       { transform: translate(-2px, -14px); }
        75%       { transform: translate(4px, -6px); }
    }

    /* ─── MOBILE ────────────────────────────────────── */
    @media (max-width: 992px) {
        .about-hero {
            min-height: auto;
            padding: 60px 0;
        }
        .hero-text-content { 
            grid-column: span 12; 
            order: 2; 
            padding-right: 0;
            margin-top: 40px;
        }
        .hero-image-content { 
            grid-column: span 12; 
            order: 1; 
            justify-content: center;
        }
        .portrait-area {
            width: min(80vw, 360px);
            transform: none; /* Reset desktop nudge on mobile */
            margin-top: 0;
        }
        .hero-title {
            font-size: 64px;
        }
        .frag { display: none; }
    }
</style>
