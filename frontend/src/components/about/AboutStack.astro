---
interface SkillItem {
    name: string;
    suffix?: string;
}

interface SkillCategory {
    header: string;
    name: string;
    items: SkillItem[];
}

interface Props {
    skills?: SkillCategory[];
}

const { skills = [] } = Astro.props;
---

{skills && skills.length > 0 && (
    <section id="skills" class="skills-section">
        <div class="section-header">
            <div class="meta-text">// SYSTEM SPECS</div>
            <h2 class="section-title">CAPABILITIES</h2>
        </div>
        
        <div class="skills-grid">
            {skills.map((category) => (
                <div class="skill-card">
                    <div class="skill-header">{category.header}</div>
                    <div class="skill-name">
                        {category.name.split(" ").map((word: string, i: number) => (
                            <>{i > 0 && <br />}{word}</>
                        ))}
                    </div>
                    <ul class="skill-list">
                        {category.items?.map((item) => (
                            <li>
                                <span>{item.name}</span>
                                {item.suffix && <span class="tag">{item.suffix}</span>}
                            </li>
                        ))}
                    </ul>
                </div>
            ))}
        </div>
    </section>
)}

<style>
    .skills-section {
        padding: var(--section-spacing) 0;
    }

    .section-header {
        margin-bottom: 64px;
    }

    .meta-text {
        font-family: var(--font-tech);
        font-size: 11px;
        text-transform: uppercase;
        color: var(--accent);
        letter-spacing: 0.2em;
        margin-bottom: 12px;
    }

    .section-title {
        font-family: var(--font-display);
        font-size: clamp(32px, 5vw, 64px);
        text-transform: uppercase;
        line-height: 1;
        color: var(--text-primary);
        margin: 0;
    }

    .skills-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 32px; /* Increased gap */
    }

    .skill-card {
        background: var(--bg-surface);
        border: 1px solid var(--border);
        padding: 40px; /* Increased from 24px */
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        min-height: 420px;
        transition: all 0.5s var(--ease-out);
        position: relative;
        overflow: hidden;
    }

    .skill-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 2px;
        background: var(--accent);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.4s var(--ease-out);
    }

    .skill-card:hover {
        transform: translateY(-8px);
        border-color: var(--border);
        box-shadow: 0 30px 60px rgba(0,0,0,0.4);
        background: var(--bg-muted);
    }

    .skill-card:hover::before {
        transform: scaleX(1);
    }

    .skill-header {
        font-family: var(--font-tech);
        font-size: 10px;
        text-transform: uppercase;
        color: var(--accent);
        letter-spacing: 0.15em;
        margin-bottom: 24px;
        opacity: 0.8;
    }

    .skill-name {
        font-family: var(--font-display);
        font-size: 40px;
        color: var(--text-primary);
        line-height: 0.9;
        text-transform: uppercase;
        margin-bottom: 40px;
    }

    .skill-list {
        list-style: none;
        padding: 0;
        margin: 0;
        margin-top: auto;
    }

    .skill-list li {
        font-family: var(--font-tech);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-primary);
        border-top: 1px solid var(--border);
        padding: 16px 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        opacity: 0.9;
    }

    .skill-list li:first-child {
        border-top: none;
    }

    .skill-list li .tag {
        font-size: 9px;
        border: 1px solid var(--border);
        color: var(--text-secondary);
        padding: 4px 10px;
        transition: all 0.3s ease;
        background: var(--bg-primary);
    }

    .skill-card:hover .tag {
        border-color: var(--accent);
        color: var(--accent);
    }

    @media (max-width: 992px) {
        .skills-grid { grid-template-columns: repeat(2, 1fr); gap: 24px; }
        .skill-card { padding: 32px; min-height: 380px; }
    }

    @media (max-width: 640px) {
        .skills-grid { grid-template-columns: 1fr; }
        .skill-card { min-height: auto; }
    }
</style>
