---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="STACK // DATA DREAMER">
    <main class="container page-content">
        <header class="page-header">
            <span class="meta-text" style="color:#999;">// SYSTEM SPECS</span>
            <h1 class="page-title">CAPABILITIES</h1>
        </header>

        <div class="skills-grid">
            <div class="skill-card">
                <div class="skill-header">01 // CORE</div>
                <div class="skill-name">DATA<br/>ANALYSIS</div>
                <ul class="skill-list">
                    <li>PYTHON <span>V3.11</span></li>
                    <li>SQL <span>ADVANCED</span></li>
                    <li>TABLEAU <span>CERTIFIED</span></li>
                    <li>PANDAS/NUMPY <span>NATIVE</span></li>
                </ul>
            </div>

            <div class="skill-card">
                <div class="skill-header">02 // FUTURE</div>
                <div class="skill-name">ARTIFICIAL<br/>INTELLIGENCE</div>
                <ul class="skill-list">
                    <li>PYTORCH <span>LEARNING</span></li>
                    <li>LLM TUNING <span>LLAMA-2</span></li>
                    <li>RAG PIPELINES <span>ACTIVE</span></li>
                    <li>COMPUTER VISION <span>OPENCV</span></li>
                </ul>
            </div>

            <div class="skill-card">
                <div class="skill-header">03 // INFRA</div>
                <div class="skill-name">HOMELAB<br/>OPS</div>
                <ul class="skill-list">
                    <li>PROXMOX <span>CLUSTER</span></li>
                    <li>DOCKER <span>CONTAINERS</span></li>
                    <li>UBUNTU SERVER <span>LTS</span></li>
                    <li>TRUE NAS <span>STORAGE</span></li>
                </ul>
            </div>
        </div>
    </main>
</MainLayout>

<style>
    .page-content {
        padding-top: 120px;
        padding-bottom: 120px;
    }

    .page-header {
        margin-bottom: 64px;
    }

    .page-title {
        font-family: var(--font-display);
        font-size: clamp(80px, 12vw, 180px);
        color: var(--color-primary);
        line-height: 0.85;
        margin-top: 12px;
    }

    .skills-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background: #e0e0e0;
        border: 1px solid #e0e0e0;
    }

    .skill-card {
        background: var(--color-bg);
        padding: 36px 32px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-height: 280px;
        transition: background 0.3s ease;
    }

    .skill-card:hover {
        background: #FFF5F5;
    }

    .skill-header {
        font-size: 12px;
        color: var(--color-primary);
        font-weight: bold;
        margin-bottom: 10px;
    }

    .skill-name {
        font-family: var(--font-display);
        font-size: 42px;
        color: var(--color-ink);
        line-height: 1;
        margin: 12px 0;
    }

    .skill-list {
        margin-top: auto;
        list-style: none;
    }

    .skill-list li {
        font-size: 11px;
        border-bottom: 1px solid #eee;
        padding: 8px 0;
        display: flex;
        justify-content: space-between;
        color: #555;
    }

    @media (prefers-color-scheme: dark) {
        .skills-grid { background: #2a2a2a; border-color: #2a2a2a; }
        .skill-card { background: #161616; }
        .skill-card:hover { background: #1f0800; }
        .skill-list li { border-color: #2a2a2a; color: #aaa; }
    }

    @media (max-width: 768px) {
        .skills-grid { grid-template-columns: 1fr; }
        .skill-card { min-height: auto; padding: 28px 20px; }
        .page-title { font-size: 60px; }
    }
</style>
