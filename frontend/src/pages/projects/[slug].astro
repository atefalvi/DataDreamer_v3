---
import MainLayout from "../../layouts/MainLayout.astro";
import TableOfContents from "../../components/blog/TableOfContents.astro";
import { fetchProjects, getAssetUrl } from "../../lib/directus";
import { renderMarkdown } from "../../lib/renderMarkdown";

const { slug } = Astro.params;
const projects = await fetchProjects();
const project = projects.find((p) => p.slug === slug);

if (!project) return Astro.redirect("/404");

const { title, description, summary, published_at, tags, cover_image, author } = project;

const dateFormatted = published_at
    ? new Date(published_at).getFullYear().toString()
    : "2024";
const imageUrl = cover_image ? getAssetUrl(cover_image) : null;

// Author display
const authorName = author
    ? `${author.first_name ?? ""} ${author.last_name ?? ""}`.trim().toUpperCase()
    : "ATEF ALVI";
const authorAvatar = author?.avatar ? getAssetUrl(author.avatar) : null;
const authorInitials = authorName
    .split(" ")
    .filter(Boolean)
    .slice(0, 2)
    .map((w: string) => w[0])
    .join("");

const { html: renderedDescription, headings } = await renderMarkdown(description || "");
---

<MainLayout
    title={`PROJECT // ${title.toUpperCase()}`}
    description={summary || "A project case study from Data Dreamer."}
    ogImage={imageUrl ?? "https://data-dreamer.net/og/project.jpg"}
    ogType="article"
>
    <main class="container page-content">
        <header class="project-hero">
            <div class="project-hero-meta">
                <span class="meta-text">// CASE_STUDY_{dateFormatted}</span>
                <div class="tag-row">
                    {tags?.map((tag: string) => <span class="project-tag">{tag}</span>)}
                </div>
            </div>
            <h1 class="project-title">{title.toUpperCase()}</h1>
            <p class="project-summary">{summary}</p>

            <!-- Meta grid: AUTHOR | PUBLISHED | TIMELINE -->
            <div class="post-meta-grid">
                <!-- Avatar spans both rows via inner grid -->
                <div class="pmg-col pmg-author-col">
                    {authorAvatar
                        ? <img class="author-avatar" src={authorAvatar} alt={authorName} />
                        : <span class="author-initials">{authorInitials || "—"}</span>
                    }
                    <span class="pmg-label">AUTHOR</span>
                    <span class="pmg-value author-name">{authorName}</span>
                </div>
                <div class="pmg-col">
                    <span class="pmg-label">PUBLISHED</span>
                    <span class="pmg-value">{published_at ? new Date(published_at).toISOString().slice(0,10).replace(/-/g,".") : "—"}</span>
                </div>
                <div class="pmg-col">
                    <span class="pmg-label">TIMELINE</span>
                    <span class="pmg-value">{dateFormatted}</span>
                </div>
            </div>
        </header>

        <div class="project-layout">
            <div class="project-main">
                {imageUrl && (
                    <div class="project-featured-image">
                        <img src={imageUrl} alt={title} />
                    </div>
                )}
                
                <div class="project-description blog-content" set:html={renderedDescription} />

                <div class="return-link">
                    <a href="/projects">← BACK TO ALL PROJECTS</a>
                </div>
            </div>

            <aside class="project-sidebar">
                <div class="sidebar-block">
                    <h3 class="sidebar-label">TIMELINE</h3>
                    <p class="sidebar-value">{dateFormatted}</p>
                </div>
                <div class="sidebar-block">
                    <h3 class="sidebar-label">TECHNOLOGIES</h3>
                    <div class="sidebar-tags">
                        {tags?.map((tag: string) => <span class="mini-tag">{tag}</span>)}
                    </div>
                </div>
                {headings && headings.length > 0 && (
                    <div class="sidebar-block toc-block">
                        <h3 class="sidebar-label">CONTENTS</h3>
                        <TableOfContents headings={headings} />
                    </div>
                )}
            </aside>
        </div>
    </main>
</MainLayout>

<style>
    .page-content {
        padding-top: 56px;
        padding-bottom: 100px;
    }

    .project-hero {
        padding: 80px 0 60px;
        border-bottom: 1px solid var(--color-border);
        margin-bottom: 60px;
    }

    .project-hero-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
    }

    .tag-row {
        display: flex;
        gap: 8px;
    }

    .project-tag {
        font-family: var(--font-tech);
        font-size: 10px;
        border: 1px solid var(--color-primary);
        padding: 3px 10px;
        color: var(--color-primary);
    }

    .project-title {
        font-family: var(--font-display);
        font-size: clamp(48px, 10vw, 120px);
        line-height: 0.85;
        margin-bottom: 40px;
        text-transform: uppercase;
        color: var(--color-primary);
    }

    .project-summary {
        font-size: 20px;
        max-width: 800px;
        line-height: 1.5;
        opacity: 0.8;
    }

    .project-layout {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 80px;
    }

    .project-featured-image {
        margin-bottom: 60px;
        background: #f5f5f5;
        aspect-ratio: 16/9;
        overflow: hidden;
    }

    .project-featured-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .project-description {
        font-size: 18px;
        line-height: 1.7;
    }

    .project-description :global(h2) {
        font-family: var(--font-display);
        font-size: 32px;
        margin-top: 60px;
        margin-bottom: 24px;
        text-transform: uppercase;
    }

    .project-description :global(h3) {
        font-family: var(--font-display);
        font-size: 24px;
        margin-top: 40px;
        margin-bottom: 16px;
        text-transform: uppercase;
    }

    /* Sidebar */
    .project-sidebar {
        border-left: 1px solid var(--color-border);
        padding-left: 40px;
        position: sticky;
        top: 100px;
        align-self: start;
        max-height: calc(100vh - 120px);
        overflow-y: auto;
    }

    /* Hide scrollbar for sidebar */
    .project-sidebar::-webkit-scrollbar {
        width: 0px;
        background: transparent;
    }
    .project-sidebar {
        scrollbar-width: none;
    }

    .sidebar-block {
        margin-bottom: 48px;
    }

    .sidebar-label {
        font-family: var(--font-tech);
        font-size: 10px;
        color: #999;
        margin-bottom: 12px;
        letter-spacing: 0.1em;
    }

    .sidebar-value {
        font-family: var(--font-display);
        font-size: 24px;
    }

    .sidebar-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .mini-tag {
        font-size: 11px;
        padding: 4px 10px;
        background: #eee;
        color: #666;
        font-family: var(--font-tech);
    }

    /* ── META GRID ──────────────────────────────── */
    .post-meta-grid {
        display: grid;
        grid-template-columns: auto auto auto;
        gap: 0 48px;
        margin-top: 40px;
        padding-top: 24px;
        border-top: 1px solid var(--color-border);
        font-family: var(--font-tech);
        align-items: start;
    }

    .pmg-col {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .pmg-label {
        font-size: 9px;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--text-secondary, #666);
        opacity: 0.6;
        white-space: nowrap;
    }

    .pmg-value {
        font-size: 12px;
        font-family: var(--font-tech);
        color: var(--color-text);
        font-weight: 500;
        letter-spacing: 0.04em;
        white-space: nowrap;
    }

    /* ── AUTHOR COLUMN ──────────────────────────── */
    .pmg-author-col {
        display: grid;
        grid-template-columns: auto 1fr;
        grid-template-rows: auto auto;
        column-gap: 10px;
    }

    .pmg-author-col .author-avatar,
    .pmg-author-col .author-initials {
        grid-column: 1;
        grid-row: 1 / 3;
        align-self: center;
    }

    .pmg-author-col .pmg-label {
        grid-column: 2;
        grid-row: 1;
        align-self: end;
    }

    .pmg-author-col .author-name {
        grid-column: 2;
        grid-row: 2;
        align-self: start;
    }

    .author-chip {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .author-name {
        font-size: 12px;
        font-family: var(--font-tech);
        font-weight: 500;
        letter-spacing: 0.04em;
    }

    .author-avatar {
        width: 34px;
        height: 34px;
        object-fit: cover;
        display: block;
        filter: grayscale(15%);
        border: 1px solid var(--color-border);
        flex-shrink: 0;
        cursor: default;
        transition: transform 0.18s ease;
        position: relative;
        z-index: 1;
    }

    @media (hover: hover) {
        .author-avatar:hover {
            transform: scale(3.5);
            transform-origin: left center;
            z-index: 20;
            border-color: var(--color-primary);
        }
    }

    .author-initials {
        width: 34px;
        height: 34px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: transparent;
        border: 1px solid var(--color-primary);
        font-family: var(--font-tech);
        font-size: 9px;
        color: var(--color-primary);
        letter-spacing: 0.08em;
        flex-shrink: 0;
    }

    @media (max-width: 768px) {
        .post-meta-grid {
            grid-template-columns: 1fr;
            gap: 16px;
            margin-top: 24px;
        }
    }

    .return-link {
        margin-top: 100px;
        padding-top: 40px;
        border-top: 1px solid var(--color-border);
    }

    .return-link a {
        font-family: var(--font-tech);
        font-size: 14px;
        text-decoration: none;
        color: var(--color-primary);
        transition: padding-left 0.2s;
    }

    .return-link a:hover {
        padding-left: 10px;
    }

    @media (max-width: 1024px) {
        .project-layout {
            grid-template-columns: 1fr;
            gap: 60px;
        }
        .project-sidebar {
            position: static;
            align-self: auto;
            max-height: none;
            overflow-y: visible;
            border-left: none;
            border-top: 1px solid var(--color-border);
            padding-left: 0;
            padding-top: 60px;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .project-hero {
            padding-top: 24px;
            padding-bottom: 24px;
            margin-bottom: 32px;
        }
        .project-title {
            font-size: 36px;
            margin-bottom: 24px;
        }
        .project-summary {
            font-size: 16px;
        }
        .project-sidebar {
            grid-template-columns: 1fr;
        }
        .project-main {
            min-width: 0;
            overflow-wrap: break-word;
        }
    }
</style>
