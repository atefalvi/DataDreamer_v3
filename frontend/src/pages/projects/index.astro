---
import MainLayout from "../../layouts/MainLayout.astro";
import ProjectCard from "../../components/projects/ProjectCard.astro";
import PageHero from "../../components/PageHero.astro";
import { fetchProjects, getAssetUrl, type Project } from "../../lib/directus";

const directusProjects = await fetchProjects();

const projects = directusProjects.map((p: Project, i: number) => ({
    title: (p.title ?? "UNTITLED").toUpperCase(),
    description: p.summary ?? p.description ?? "",
    image: p.cover_image ? getAssetUrl(p.cover_image) : null,
    index: `EXP.${String(i + 1).padStart(2, "0")}`,
    year: p.published_at
        ? new Date(p.published_at).getFullYear().toString()
        : "2024",
    tags: p.tags ?? [],
    href: p.slug ? `/projects/${p.slug}` : "#",
}));

// Extract unique tags and sort them alphabetically
const uniqueTags = [...new Set(projects.flatMap((p) => p.tags))].sort((a, b) =>
    a.toLowerCase().localeCompare(b.toLowerCase())
);
---

<MainLayout title="PROJECTS // DATA DREAMER">
    <main class="container page-content">
        <PageHero label="// PROJECT INDEX" title="DEEP WORKSPACE" />

        <div class="filter-bar">
            <button class="filter-btn active" data-tag="all" aria-pressed="true">All Deployments</button>
            {
                uniqueTags.map((tag) => (
                    <button class="filter-btn" data-tag={tag.toLowerCase()} aria-pressed="false">
                        {tag}
                    </button>
                ))
            }
        </div>

        {projects.length === 0 ? (
            <div class="empty-state">
                <p class="meta-text">// NO PROJECTS FOUND — CHECK BACK SOON.</p>
            </div>
        ) : (
            <div class="projects-grid">
                {projects.map((project) => (
                    <div
                        class="project-item"
                        data-tags={project.tags.map((t) => t.toLowerCase()).join(",")}
                    >
                        <ProjectCard
                            title={project.title}
                            description={project.description}
                            image={project.image}
                            index={project.index}
                            year={project.year}
                            tags={project.tags}
                            href={project.href}
                        />
                    </div>
                ))}
            </div>
        )}
    </main>
</MainLayout>

<style>
    .page-content {
        padding-top: 56px;
    }

    /* .filter-bar, .filter-btn → global.css */

    .empty-state {
        padding: 80px 0;
        text-align: center;
    }

    .projects-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 40px;
        margin-bottom: 100px;
    }

    @media (max-width: 1024px) {
        .projects-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .page-content {
            padding-top: 32px;
        }
        .filter-bar {
            flex-wrap: nowrap;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            padding-bottom: 8px;
            margin-bottom: -8px;
        }
        .filter-bar::-webkit-scrollbar {
            height: 4px;
        }
        .filter-btn {
            flex-shrink: 0;
            font-size: 11px;
            padding: 8px 16px;
        }
        .projects-grid {
            grid-template-columns: 1fr;
            gap: 60px;
        }
    }
</style>

<script>
    const buttons = document.querySelectorAll(".filter-btn");
    const items = document.querySelectorAll(
        ".project-item",
    ) as NodeListOf<HTMLElement>;

    buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
            const filterTag = btn.getAttribute("data-tag")?.toLowerCase();

            // Toggle active state + aria-pressed
            buttons.forEach((b) => { b.classList.remove("active"); b.setAttribute("aria-pressed", "false"); });
            btn.classList.add("active");
            btn.setAttribute("aria-pressed", "true");

            // Filter items
            items.forEach((item) => {
                const itemTags = item.getAttribute("data-tags")?.split(",") ?? [];

                if (filterTag === "all" || itemTags.includes(filterTag ?? "")) {
                    item.style.display = "block";
                } else {
                    item.style.display = "none";
                }
            });
        });
    });
</script>
