---
import MainLayout from "../../layouts/MainLayout.astro";
import ProjectCard from "../../components/projects/ProjectCard.astro";
import { fetchProjects, getAssetUrl } from "../../lib/directus";

const directusProjects = await fetchProjects();

// Static fallback data when Directus is offline
const projects = directusProjects.map((p: any, i: number) => ({
    title: (p.title ?? "UNTITLED").toUpperCase(),
    description: p.summary ?? p.description ?? "",
    image: p.cover_image ? getAssetUrl(p.cover_image) : null,
    index: `EXP.${String(i + 1).padStart(2, "0")}`,
    year: p.published_at
        ? new Date(p.published_at).getFullYear().toString()
        : "2024",
    tags: p.tags ?? [],
    href: p.slug ? `/projects/${p.slug}` : "#",
}));

// Extract unique tags and sort them alphabetically
const uniqueTags = [...new Set(projects.flatMap((p: any) => p.tags))].sort((a: any, b: any) => {
    return a.toLowerCase().localeCompare(b.toLowerCase());
});
---

<MainLayout title="PROJECTS // DATA DREAMER">
    <main class="container page-content">
        <header class="page-hero-header">
            <span class="meta-text">// PROJECT INDEX</span>
            <h1 class="page-title">DEEP<br />WORKSPACE</h1>
        </header>

        <div class="filter-bar">
            <button class="filter-btn active" data-tag="all">All Deployments</button>
            {
                uniqueTags.map((tag: any) => (
                    <button class="filter-btn" data-tag={tag.toLowerCase()}>
                        {tag}
                    </button>
                ))
            }
        </div>

        <div class="projects-grid">
            {
                projects.map((project: any) => (
                    <div
                        class="project-item"
                        data-tags={JSON.stringify(
                            project.tags.map((t: string) => t.toLowerCase()),
                        )}
                    >
                        <ProjectCard
                            title={project.title}
                            description={project.description}
                            image={project.image}
                            index={project.index}
                            year={project.year}
                            tags={project.tags}
                            href={project.href}
                        />
                    </div>
                ))
            }
        </div>
    </main>
</MainLayout>

<style>
    .page-content {
        padding-top: 56px;
    }

    .filter-bar {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        border-top: 1px solid var(--color-gray);
        border-bottom: 1px solid var(--color-gray);
        padding: 24px 0;
        margin-bottom: 60px;
    }

    .filter-btn {
        background: none;
        border: 1px solid var(--border);
        padding: 6px 16px;
        font-family: var(--font-tech);
        font-size: 10px;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.2s;
        color: var(--text-secondary);
    }

    .filter-btn:hover,
    .filter-btn.active {
        background: var(--color-primary);
        color: white;
        border-color: var(--color-primary);
    }

    .projects-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 40px;
        margin-bottom: 100px;
    }

    @media (max-width: 1024px) {
        .projects-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .page-content {
            padding-top: 32px;
        }
        .filter-bar {
            flex-wrap: nowrap;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            padding-bottom: 8px;
            margin-bottom: -8px;
        }
        .filter-bar::-webkit-scrollbar {
            height: 4px;
        }
        .filter-btn {
            flex-shrink: 0;
            font-size: 11px;
            padding: 8px 16px;
        }
        .projects-grid {
            grid-template-columns: 1fr;
            gap: 60px;
        }
    }
</style>

<script>
    const buttons = document.querySelectorAll(".filter-btn");
    const items = document.querySelectorAll(
        ".project-item",
    ) as NodeListOf<HTMLElement>;

    buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
            const filterTag = btn.getAttribute("data-tag")?.toLowerCase();

            // Toggle active state
            buttons.forEach((b) => b.classList.remove("active"));
            btn.classList.add("active");

            // Filter items
            items.forEach((item) => {
                const itemTagsStr = item.getAttribute("data-tags");
                const itemTags = JSON.parse(itemTagsStr || "[]");

                if (filterTag === "all" || itemTags.includes(filterTag)) {
                    item.style.display = "block";
                } else {
                    item.style.display = "none";
                }
            });
        });
    });
</script>
