---
import MainLayout from "../layouts/MainLayout.astro";
import { fetchSiteSettings } from "../lib/directus";

const siteSettings = await fetchSiteSettings();
const email    = siteSettings?.email    || "hello@data-dreamer.net";
const github   = siteSettings?.github   || "github.com/datadreamer";
const linkedin = siteSettings?.linkedin || "linkedin.com/in/datadreamer";
const twitter  = siteSettings?.twitter  || null;

const channels = [
    { label: "EMAIL",    protocol: "MAILTO", address: email,    href: `mailto:${email}` },
    { label: "GITHUB",   protocol: "HTTPS",  address: github,   href: `https://${github}`, external: true },
    { label: "LINKEDIN", protocol: "HTTPS",  address: linkedin, href: `https://${linkedin}`, external: true },
    ...(twitter ? [{ label: "TWITTER / X", protocol: "HTTPS", address: twitter, href: `https://${twitter}`, external: true }] : []),
];
---

<MainLayout
    title="CONNECT // DATA DREAMER"
    description="Get in touch — available for remote, hybrid, or onsite engagements."
    ogType="website"
>
    <main class="connect-page container">

        <!-- ── HERO ──────────────────────────────────── -->
        <header class="connect-hero">
            <span class="meta-text">// CONNECT</span>
            <h1 class="connect-heading">
                <span class="ch-word">INITIATE</span>
                <span class="ch-word">CONTACT</span>
                <span class="ch-word ch-accent">SEQUENCE_</span>
            </h1>
        </header>

        <!-- ── STATUS BLOCK ──────────────────────────── -->
        <div class="status-block">
            <div class="status-row">
                <span class="status-label">STATUS</span>
                <span class="status-value">
                    <span class="status-dot"></span>
                    AVAILABLE FOR HIRE
                </span>
            </div>
            <div class="status-row">
                <span class="status-label">LOCATION</span>
                <span class="status-value">REMOTE / HYBRID / ONSITE</span>
            </div>
            <div class="status-row">
                <span class="status-label">TIMEZONE</span>
                <span class="status-value">EST (UTC−5)</span>
            </div>
            <div class="status-row">
                <span class="status-label">RESPONSE</span>
                <span class="status-value">WITHIN 24 HRS</span>
            </div>
        </div>

        <!-- ── CHANNEL TABLE ──────────────────────────── -->
        <section class="channels-section">
            <div class="channels-header">
                <span>CHANNEL</span>
                <span>PROTOCOL</span>
                <span>ADDRESS</span>
            </div>

            {channels.map(ch => (
                <a
                    href={ch.href}
                    class="channel-row"
                    target={ch.external ? "_blank" : undefined}
                    rel={ch.external ? "noopener noreferrer" : undefined}
                    aria-label={`Contact via ${ch.label}`}
                >
                    <span class="ch-label">{ch.label}</span>
                    <span class="ch-protocol">{ch.protocol}</span>
                    <span class="ch-address">
                        {ch.address.toUpperCase()}
                        <span class="ch-arrow" aria-hidden="true">→</span>
                    </span>
                </a>
            ))}
        </section>

        <!-- ── FOOTER NOTE ────────────────────────────── -->
        <p class="connect-note">
            // PREFER EMAIL FOR PROJECT INQUIRIES. GITHUB FOR COLLABORATION REQUESTS.
        </p>

    </main>
</MainLayout>

<style>
    .connect-page {
        padding-top: 56px;
        padding-bottom: 120px;
        min-height: 90vh;
    }

    /* ── HERO ─────────────────────────────────────── */
    .connect-hero {
        padding: 80px 0 72px;
        border-bottom: 1px solid var(--border);
    }

    .connect-heading {
        font-family: var(--font-display);
        font-size: clamp(64px, 12vw, 160px);
        line-height: 0.85;
        text-transform: uppercase;
        margin-top: 24px;
        display: flex;
        flex-direction: column;
    }

    .ch-word {
        display: block;
        color: var(--text-primary);
        transition: transform 0.4s var(--ease-out), color 0.2s;
        transform-origin: left;
        cursor: default;
    }

    .ch-word:hover {
        transform: skewX(-8deg) translateX(24px);
        color: var(--accent);
    }

    .ch-accent {
        color: var(--accent);
    }

    /* ── STATUS BLOCK ─────────────────────────────── */
    .status-block {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
        border-bottom: 1px solid var(--border);
        margin: 64px 0;
    }

    .status-row {
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding: 32px 0;
        border-right: 1px solid var(--border);
        padding-right: 32px;
        margin-right: 32px;
    }

    .status-row:last-child {
        border-right: none;
        margin-right: 0;
        padding-right: 0;
    }

    .status-label {
        font-family: var(--font-tech);
        font-size: 9px;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: var(--text-secondary);
        opacity: 0.6;
    }

    .status-value {
        font-family: var(--font-tech);
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--text-primary);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .status-dot {
        width: 6px;
        height: 6px;
        background: #00cc66;
        border-radius: 50%;
        display: inline-block;
        animation: pulse-dot 2s ease-in-out infinite;
        flex-shrink: 0;
    }

    @keyframes pulse-dot {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%       { opacity: 0.5; transform: scale(0.75); }
    }

    /* ── CHANNEL TABLE ────────────────────────────── */
    .channels-section {
        border-top: 2px solid var(--text-primary);
    }

    .channels-header {
        display: grid;
        grid-template-columns: 180px 140px 1fr;
        gap: 0 32px;
        padding: 16px 0;
        border-bottom: 1px solid var(--border);
        font-family: var(--font-tech);
        font-size: 9px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--text-secondary);
        opacity: 0.5;
    }

    .channel-row {
        display: grid;
        grid-template-columns: 180px 140px 1fr;
        gap: 0 32px;
        padding: 28px 0;
        border-bottom: 1px solid var(--border);
        text-decoration: none;
        align-items: center;
        transition: background 0.2s var(--ease-out), padding 0.2s var(--ease-out);
        cursor: crosshair;
    }

    .channel-row:hover {
        background: var(--bg-muted);
        padding-left: 16px;
        margin-left: -16px;
        padding-right: 16px;
    }

    .ch-label {
        font-family: var(--font-display);
        font-size: clamp(24px, 3vw, 40px);
        text-transform: uppercase;
        color: var(--text-primary);
        transition: color 0.2s;
        line-height: 1;
    }

    .channel-row:hover .ch-label {
        color: var(--accent);
    }

    .ch-protocol {
        font-family: var(--font-tech);
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--text-secondary);
        opacity: 0.5;
        align-self: center;
    }

    .ch-address {
        font-family: var(--font-tech);
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--text-primary);
        display: flex;
        align-items: center;
        gap: 12px;
        transition: color 0.2s;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .channel-row:hover .ch-address {
        color: var(--accent);
    }

    .ch-arrow {
        opacity: 0;
        transform: translateX(-8px);
        transition: opacity 0.2s, transform 0.2s var(--ease-out);
        flex-shrink: 0;
    }

    .channel-row:hover .ch-arrow {
        opacity: 1;
        transform: translateX(0);
    }

    /* ── FOOTER NOTE ──────────────────────────────── */
    .connect-note {
        margin-top: 60px;
        font-family: var(--font-tech);
        font-size: 11px;
        color: var(--text-secondary);
        opacity: 0.5;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    /* ── MOBILE ───────────────────────────────────── */
    @media (max-width: 768px) {
        .connect-hero {
            padding: 48px 0 48px;
        }

        .status-block {
            grid-template-columns: 1fr 1fr;
            margin: 40px 0;
        }

        .status-row {
            padding: 20px 16px 20px 0;
            margin-right: 16px;
        }

        .status-row:nth-child(even) {
            border-right: none;
            margin-right: 0;
            padding-right: 0;
        }

        .channels-header {
            display: none;
        }

        .channel-row {
            grid-template-columns: 1fr auto;
            grid-template-rows: auto auto;
            gap: 4px 16px;
            padding: 20px 0;
        }

        .channel-row:hover {
            margin-left: -12px;
            padding-left: 12px;
        }

        .ch-label {
            grid-column: 1;
            grid-row: 1;
            font-size: 28px;
        }

        .ch-address {
            grid-column: 1;
            grid-row: 2;
            font-size: 11px;
            opacity: 0.7;
        }

        .ch-protocol {
            grid-column: 2;
            grid-row: 1 / 3;
            align-self: center;
        }

        .ch-arrow {
            display: none;
        }
    }
</style>
