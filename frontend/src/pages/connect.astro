---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="CONNECT // DATA DREAMER">
    <main class="container page-content">
        <header class="page-header">
            <span class="meta-text" style="color:#999;">// TRANSMISSION</span>
            <h1 class="page-title">CONNECT</h1>
        </header>

        <div class="connect-grid">
            <section class="connect-block">
                <h2 class="block-label">AVAILABILITY</h2>
                <div class="block-body">
                    <p class="status-line"><span class="status-dot"></span> Currently accepting new projects</p>
                    <ul class="availability-list">
                        <li><span>MODE</span><span>REMOTE / HYBRID / ONSITE</span></li>
                        <li><span>TIMEZONE</span><span>EST (UTC-5)</span></li>
                        <li><span>RESPONSE</span><span>&lt; 24 HOURS</span></li>
                    </ul>
                </div>
            </section>

            <section class="connect-block">
                <h2 class="block-label">DIRECT CHANNELS</h2>
                <div class="block-body">
                    <a href="mailto:hello@data-dreamer.net" class="channel-link">
                        <span class="channel-label">EMAIL</span>
                        <span class="channel-value">HELLO@DATA-DREAMER.NET</span>
                    </a>
                    <a href="https://github.com/datadreamer" target="_blank" rel="noopener" class="channel-link">
                        <span class="channel-label">GITHUB</span>
                        <span class="channel-value">GITHUB.COM/DATADREAMER</span>
                    </a>
                    <a href="https://linkedin.com/in/datadreamer" target="_blank" rel="noopener" class="channel-link">
                        <span class="channel-label">LINKEDIN</span>
                        <span class="channel-value">LINKEDIN.COM/IN/DATADREAMER</span>
                    </a>
                </div>
            </section>

            <section class="connect-block connect-block--wide">
                <h2 class="block-label">WHAT I BUILD</h2>
                <div class="services-grid">
                    <div class="service-item">
                        <h3 class="service-title">DATA PIPELINES</h3>
                        <p class="service-desc">End-to-end ETL architecture, from ingestion to insight delivery.</p>
                    </div>
                    <div class="service-item">
                        <h3 class="service-title">ML MODELS</h3>
                        <p class="service-desc">Predictive analytics, NLP engines, and custom model training.</p>
                    </div>
                    <div class="service-item">
                        <h3 class="service-title">INFRA OPS</h3>
                        <p class="service-desc">Self-hosted clusters, containerized deployments, monitoring stacks.</p>
                    </div>
                    <div class="service-item">
                        <h3 class="service-title">DASHBOARDS</h3>
                        <p class="service-desc">Interactive Tableau and D3.js visualizations for stakeholder reporting.</p>
                    </div>
                </div>
            </section>
        </div>
    </main>
</MainLayout>

<style>
    .page-content {
        padding-top: 120px;
        padding-bottom: 120px;
    }

    .page-header {
        margin-bottom: 64px;
    }

    .page-title {
        font-family: var(--font-display);
        font-size: clamp(80px, 12vw, 180px);
        color: var(--color-primary);
        line-height: 0.85;
        margin-top: 12px;
    }

    .connect-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1px;
        background: var(--color-gray);
        border: 1px solid var(--color-gray);
    }

    .connect-block {
        background: var(--color-bg);
        padding: 48px 40px;
    }

    .connect-block--wide {
        grid-column: 1 / -1;
    }

    .block-label {
        font-family: var(--font-tech);
        font-size: 10px;
        color: var(--color-primary);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 24px;
    }

    .block-body {
        font-size: 13px;
    }

    .status-line {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 24px;
        font-size: 12px;
        color: #555;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #00FF87;
        box-shadow: 0 0 8px #00FF87;
        animation: pulse 2.5s ease-in-out infinite;
    }

    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
    }

    .availability-list {
        list-style: none;
    }

    .availability-list li {
        display: flex;
        justify-content: space-between;
        font-size: 11px;
        padding: 10px 0;
        border-bottom: 1px solid var(--color-gray);
        color: #555;
    }

    .channel-link {
        display: flex;
        justify-content: space-between;
        align-items: center;
        text-decoration: none;
        color: var(--color-ink);
        padding: 16px 0;
        border-bottom: 1px solid var(--color-gray);
        font-size: 12px;
        transition: padding-left 0.2s, background 0.2s;
    }

    .channel-link:hover {
        padding-left: 12px;
        color: var(--color-primary);
    }

    .channel-label {
        font-size: 10px;
        color: #999;
        letter-spacing: 0.1em;
    }

    .channel-value {
        font-weight: 700;
    }

    .services-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 32px;
    }

    .service-title {
        font-family: var(--font-display);
        font-size: 24px;
        line-height: 1;
        margin-bottom: 12px;
        color: var(--color-ink);
    }

    .service-desc {
        font-size: 12px;
        color: #666;
        line-height: 1.6;
    }

    @media (prefers-color-scheme: dark) {
        .connect-grid { background: #2a2a2a; border-color: #2a2a2a; }
        .connect-block { background: #0d0d0d; }
        .status-line { color: #aaa; }
        .availability-list li { color: #aaa; border-color: #2a2a2a; }
        .channel-link { color: #eee; border-color: #2a2a2a; }
        .service-desc { color: #aaa; }
    }

    @media (max-width: 1024px) {
        .services-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 768px) {
        .connect-grid { grid-template-columns: 1fr; }
        .connect-block { padding: 32px 24px; }
        .services-grid { grid-template-columns: 1fr; }
        .page-title { font-size: 60px; }
    }
</style>
