---
import MainLayout from "../layouts/MainLayout.astro";
import AboutHero from "../components/about/AboutHero.astro";
import AboutStats from "../components/about/AboutStats.astro";
import AboutTimeline from "../components/about/AboutTimeline.astro";
import AboutStack from "../components/about/AboutStack.astro";

import { fetchAbout } from "../lib/directus";

// Fetch data from Directus
const aboutData = await fetchAbout();

// Default values handled by components if these are null/undefined,
// but we pass them explicitly from the fetched singletons here.
const heroTagline = aboutData?.hero_tagline || undefined;
const heroTitle = aboutData?.hero_title || undefined;
const heroDescription = aboutData?.hero_description || undefined;
const profileImageId = aboutData?.profile_image || undefined;
const resumeId = aboutData?.resume || undefined;

const stats = aboutData?.stats || undefined;
const experience = aboutData?.experience || undefined;
const skills = aboutData?.skills || undefined;

---

<MainLayout title="ABOUT // DATA DREAMER">
    <AboutHero 
        tagline={heroTagline}
        title={heroTitle}
        description={heroDescription}
        imageFileId={profileImageId}
        resumeId={resumeId}
    />
    
    <AboutStats stats={stats} />
    
    <main class="container">
        <AboutTimeline experience={experience} />
        <AboutStack skills={skills} />
    </main>
</MainLayout>

<style>
    /* Body styles are handled globally by MainLayout and individual components */
</style>
