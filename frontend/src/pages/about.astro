---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="ABOUT // DATA DREAMER">
    <main class="container page-content">
        <header class="page-header">
            <span class="meta-text" style="color:#999;">// PROFILE</span>
            <h1 class="page-title">ABOUT</h1>
        </header>

        <div class="about-grid">
            <section class="about-block">
                <h2 class="block-label">01 // MISSION</h2>
                <p class="block-body">
                    Data Dreamer is a full-stack analyst and homelab operator
                    building at the intersection of data science, machine learning,
                    and self-hosted infrastructure. Every system is a signal.
                    Every signal is an opportunity to build intelligence.
                </p>
            </section>

            <section class="about-block">
                <h2 class="block-label">02 // BACKGROUND</h2>
                <p class="block-body">
                    Trained in quantitative analysis with deep experience across
                    retail analytics, NLP pipelines, and predictive modeling.
                    Holds advanced proficiency in Python, SQL, and Tableau with
                    active certifications. Currently exploring transformer architectures
                    and local LLM deployment on bare-metal clusters.
                </p>
            </section>

            <section class="about-block">
                <h2 class="block-label">03 // CURRENT FOCUS</h2>
                <ul class="focus-list">
                    <li><span class="focus-item">Fine-tuning open-source LLMs</span><span class="focus-status">ACTIVE</span></li>
                    <li><span class="focus-item">Proxmox HA cluster optimization</span><span class="focus-status">ONGOING</span></li>
                    <li><span class="focus-item">RAG pipeline engineering</span><span class="focus-status">R&D</span></li>
                    <li><span class="focus-item">Real-time sentiment analysis</span><span class="focus-status">DEPLOYED</span></li>
                </ul>
            </section>

            <section class="about-block">
                <h2 class="block-label">04 // PHILOSOPHY</h2>
                <div class="pull-quote">
                    "BUILD THE INFRASTRUCTURE.<br/>
                    OWN THE DATA.<br/>
                    TRAIN THE MODEL.<br/>
                    SHIP THE INSIGHT."
                </div>
            </section>
        </div>
    </main>
</MainLayout>

<style>
    .page-content {
        padding-top: 120px;
        padding-bottom: 120px;
    }

    .page-header {
        margin-bottom: 64px;
    }

    .page-title {
        font-family: var(--font-display);
        font-size: clamp(80px, 12vw, 180px);
        color: var(--color-primary);
        line-height: 0.85;
        margin-top: 12px;
    }

    .about-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1px;
        background: var(--color-gray);
        border: 1px solid var(--color-gray);
    }

    .about-block {
        background: var(--color-bg);
        padding: 48px 40px;
    }

    .block-label {
        font-family: var(--font-tech);
        font-size: 12px;
        color: var(--color-primary);
        font-weight: 700;
        margin-bottom: 24px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .block-body {
        font-size: 14px;
        line-height: 1.8;
        color: #555;
        max-width: 500px;
    }

    .focus-list {
        list-style: none;
    }

    .focus-list li {
        font-size: 12px;
        border-bottom: 1px solid var(--color-gray);
        padding: 12px 0;
        display: flex;
        justify-content: space-between;
        color: #555;
    }

    .focus-status {
        color: var(--color-primary);
        font-weight: 700;
        font-size: 10px;
    }

    .pull-quote {
        font-family: var(--font-display);
        font-size: 28px;
        color: var(--color-primary);
        line-height: 1.2;
        padding: 32px;
        background: #FFF5F5;
        border-right: 8px solid var(--color-primary);
    }

    @media (prefers-color-scheme: dark) {
        .block-body { color: #aaa; }
        .focus-list li { color: #aaa; border-color: #2a2a2a; }
        .about-block { background: #0d0d0d; }
        .about-grid { background: #2a2a2a; border-color: #2a2a2a; }
        .pull-quote { background: #1f0800; }
    }

    @media (max-width: 768px) {
        .about-grid { grid-template-columns: 1fr; }
        .about-block { padding: 32px 24px; }
        .page-title { font-size: 60px; }
    }
</style>
