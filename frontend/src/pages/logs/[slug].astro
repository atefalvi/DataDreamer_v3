---
import MainLayout from "../../layouts/MainLayout.astro";
import TableOfContents from "../../components/blog/TableOfContents.astro";
import RelatedLogs from "../../components/blog/RelatedLogs.astro";
import AuthorChip from "../../components/blog/AuthorChip.astro";
import { getLogBySlug, getLogs, getAuthorInitials, type ContentLog } from "../../lib/content";
import { renderMarkdown } from "../../lib/renderMarkdown";

const { slug } = Astro.params;
let post: ContentLog | null = null;
let allLogs: ContentLog[] = [];

if (slug) {
    post = await getLogBySlug(slug);
    allLogs = await getLogs();
}

if (!post) {
    return Astro.redirect("/logs");
}

// Render markdown content
const { html: renderedContent, headings } = await renderMarkdown(post.content);

// Compute author initials for fallback
const authorInitials = getAuthorInitials(post.authorName ?? "");
---

<MainLayout
    title={`LOG // ${post.title}`}
    description={post.excerpt || "A technical log from Data Dreamer."}
    ogImage="https://data-dreamer.net/og/log.jpg"
    ogImageAlt={post.title}
    ogImageType="image/jpeg"
    ogType="article"
    articlePublishedTime={post.date ? new Date(post.date).toISOString() : undefined}
    articleAuthor={post.authorName ?? "Atef Alvi"}
>
    <!-- Post Hero -->
    <div class="container post-hero">
        <div class="post-hero-meta">
            <span
                >// LOG_ENTRY_{
                    post.logNumber?.toString().padStart(3, "0") ?? "000"
                }</span
            >
            <span class="meta-sep">|</span>
            {post.tag && <span class="meta-tag">{post.tag}</span>}
            {
                post.seriesLabel && (
                    <>
                        <span class="meta-sep">|</span>
                        <span>{post.seriesLabel}</span>
                    </>
                )
            }
        </div>
        <h1 class="post-hero-title">{post.title}</h1>
        <p class="post-hero-desc">{post.excerpt}</p>
        <div class="post-meta-grid">
            <!-- Col 1: Author -->
            <AuthorChip
                name={post.authorName ?? "ATEF ALVI"}
                initials={authorInitials}
                avatarUrl={post.authorAvatar}
            />
            <!-- Col 2: Published -->
            <div class="pmg-col">
                <span class="pmg-label">PUBLISHED</span>
                <span class="pmg-value">{post.date}</span>
            </div>
            <!-- Col 3: Log number -->
            <div class="pmg-col">
                <span class="pmg-label">LOG</span>
                <span class="pmg-value">#{ post.logNumber?.toString().padStart(3, "0") ?? "000" }</span>
            </div>
        </div>
    </div>

    <!-- Blog Layout: TOC + Article -->
    <div class="container blog-container">
        <TableOfContents headings={headings} />

        <article class="blog-content">
            <Fragment set:html={renderedContent} />
        </article>
    </div>

    <!-- Related Logs Component -->
    <RelatedLogs
        currentSlug={slug || ""}
        posts={allLogs.map((l) => ({
            slug: l.slug,
            title: l.title,
            summary: l.excerpt,
        }))}
    />
</MainLayout>

<style>
    .post-hero {
        padding-top: calc(var(--nav-h) + 64px);
        padding-bottom: 48px;
        border-bottom: 2px solid var(--color-border);
    }

    .post-hero-meta {
        font-size: 11px;
        color: var(--color-primary);
        margin-bottom: 16px;
        font-weight: 700;
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        align-items: center;
        font-family: var(--font-tech);
    }

    .meta-tag {
        border: 1px solid var(--color-primary);
        padding: 2px 8px;
        font-size: 10px;
    }

    .meta-sep {
        opacity: 0.3;
    }

    .post-hero-title {
        font-family: var(--font-display);
        font-size: clamp(56px, 8vw, 96px);
        line-height: 0.88;
        margin-bottom: 32px;
        text-transform: uppercase;
        color: var(--color-primary);
    }

    .post-hero-desc {
        font-size: 18px;
        line-height: 1.6;
        max-width: 860px;
        border-left: 3px solid var(--color-primary);
        padding-left: 24px;
        opacity: 0.9;
        margin-bottom: 32px;
    }

    /* .post-meta-grid, .pmg-*, .author-avatar, .author-initials → global.css */

    .blog-container {
        padding-top: 64px;
        padding-bottom: 100px;
        display: grid;
        grid-template-columns: 240px 1fr;
        gap: 80px;
    }

    .blog-content {
        max-width: 800px;
    }

    .return-link {
        margin-top: 80px;
        padding-top: 40px;
        border-top: 1px solid var(--color-border);
    }

    .return-link a {
        font-family: var(--font-tech);
        font-size: 14px;
        color: var(--color-primary);
        text-decoration: none;
        transition: padding-left 0.2s;
    }

    .return-link a:hover {
        padding-left: 8px;
    }

    @media (max-width: 1024px) {
        .blog-container {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 768px) {
        .blog-content {
            min-width: 0;
            overflow-wrap: break-word;
        }
        /* Hide redundant H1 from markdown payload if it exists */
        .blog-content :global(h1:first-child) {
            display: none;
        }
        .post-hero {
            padding-top: calc(var(--nav-h) + 24px);
            padding-bottom: 24px;
        }
        .post-hero-title {
            font-size: 36px;
            margin-bottom: 16px;
        }
        .post-hero-desc {
            font-size: 16px;
            margin-bottom: 24px;
        }
        /* Stacked: author first, then published + log as individual rows */
        .post-meta-grid {
            grid-template-columns: 1fr;
            gap: 16px;
        }
        .blog-container {
            padding-top: 40px;
            gap: 40px;
        }
    }
</style>
