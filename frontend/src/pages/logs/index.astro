---
import MainLayout from "../../layouts/MainLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { fetchLogs, type Log } from "../../lib/directus";
import { formatDate, formatAuthorName } from "../../lib/content";

const directusLogs = await fetchLogs();

const logs = directusLogs.map((l: Log) => ({
    slug: l.slug ?? "",
    title: (l.title ?? "UNTITLED").toUpperCase(),
    date: formatDate(l.published_at),
    tag: (l.tag ?? l.category ?? "").toUpperCase(),
    authorName: formatAuthorName(l.author),
}));

const uniqueTags = [...new Set(logs.map((l) => l.tag).filter(Boolean))].sort();
const uniqueAuthors = [
    ...new Set(logs.map((l) => l.authorName).filter(Boolean)),
].sort();
---

<MainLayout title="DEV LOG // DATA DREAMER">
    <main class="container page-content">
        <PageHero label="// TERMINAL LOGS" title="DEV LOG" />

        <div class="filters-container">
            <div class="filter-group">
                <span class="filter-label">// TAGS</span>
                <div class="filter-bar">
                    <button
                        class="filter-btn active"
                        data-filter-type="tag"
                        data-val="all"
                        aria-pressed="true">ALL LOGS</button
                    >
                    {
                        uniqueTags.map((tag) => (
                            <button
                                class="filter-btn"
                                data-filter-type="tag"
                                data-val={tag}
                                aria-pressed="false"
                            >
                                {tag}
                            </button>
                        ))
                    }
                </div>
            </div>

            <div class="filter-group">
                <span class="filter-label">// AUTHOR</span>
                <div class="filter-bar">
                    <button
                        class="filter-btn active"
                        data-filter-type="author"
                        data-val="all"
                        aria-pressed="true">ALL</button
                    >
                    {
                        uniqueAuthors.map((author) => (
                            <button
                                class="filter-btn"
                                data-filter-type="author"
                                data-val={author}
                                aria-pressed="false"
                            >
                                {author}
                            </button>
                        ))
                    }
                </div>
            </div>
        </div>

        <ul class="log-list">
            {
                logs.map((post) => (
                    <li
                        class="log-item"
                        data-tag={post.tag}
                        data-author={post.authorName}
                    >
                        <a href={`/logs/${post.slug}`} class="log-link">
                            <div class="log-date">{post.date}</div>
                            <div class="log-title">{post.title}</div>
                            <div class="log-tag">{post.tag}</div>
                        </a>
                    </li>
                ))
            }
        </ul>

        {
            logs.length === 0 && (
                <div class="empty-state">
                    <p class="meta-text">// NO LOGS FOUND — SYSTEM IDLE</p>
                </div>
            )
        }
    </main>
</MainLayout>

<style>
    .page-content {
        padding-top: 56px;
    }

    .log-list {
        list-style: none;
        margin-bottom: 100px;
    }

    .filters-container {
        display: flex;
        flex-direction: row;         /* TAGS + AUTHOR in one row */
        align-items: flex-start;
        gap: 0;
        margin-bottom: 60px;
        border-top: 1px solid var(--color-gray);
        border-bottom: 1px solid var(--color-gray);
        padding: 20px 0;
    }

    /* TAGS — grows to fill remaining width */
    .filter-group:first-child {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 10px;
        padding-right: 32px;
        border-right: 1px solid var(--color-gray);
    }

    /* AUTHOR — compact, fixed to the right */
    .filter-group:last-child {
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        gap: 10px;
        padding-left: 32px;
        min-width: 200px;
    }

    .filter-label {
        font-family: var(--font-tech);
        font-size: 10px;
        color: var(--color-primary);
        letter-spacing: 0.1em;
    }

    /* Tags wrap naturally — no JS needed for overflow */
    .filter-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .log-item {
        border-bottom: 1px solid var(--color-border);
    }
    .log-link {
        display: flex;
        align-items: center;
        gap: 24px;
        padding: 24px 8px;
        text-decoration: none;
        color: inherit;
        transition:
            background 0.25s ease,
            padding-left 0.25s ease;
    }
    .log-link:hover {
        background: var(--color-primary);
        padding-left: 16px;
    }
    .log-link:hover * {
        color: white;
    }
    .log-link:hover .log-tag {
        border-color: white;
    }
    .log-date {
        width: 110px;
        flex-shrink: 0;
        font-size: 11px;
        color: var(--text-secondary);
    }
    .log-title {
        font-family: var(--font-display);
        font-size: 28px;
        flex-grow: 1;
        line-height: 1;
    }
    .log-tag,
    .log-author {
        font-size: 10px;
        border: 1px solid var(--border);
        padding: 3px 8px;
        flex-shrink: 0;
        color: var(--text-secondary);
    }
    .empty-state {
        padding: 80px 0;
        text-align: center;
    }

    @media (max-width: 768px) {
        /* Stack filters back to column on mobile */
        .filters-container {
            flex-direction: column;
            gap: 16px;
        }
        .filter-group:first-child {
            padding-right: 0;
            border-right: none;
            border-bottom: 1px solid var(--color-gray);
            padding-bottom: 16px;
        }
        .filter-group:last-child {
            padding-left: 0;
            min-width: 0;
        }
        .log-link {
            flex-wrap: wrap;
            gap: 8px;
            padding: 16px 8px;
        }
        .log-date {
            width: auto;
        }
        .log-title {
            font-size: 20px;
            flex-basis: 100%;
            order: 3;
        }
        .log-tag {
            order: 2;
            margin-left: auto;
        }
    }
</style>

<script>
    const buttons = document.querySelectorAll(".filter-btn");
    const items = document.querySelectorAll(
        ".log-item",
    ) as NodeListOf<HTMLElement>;

    let activeTag = "all";
    let activeAuthor = "all";

    // Set ALL LOGS active by default for tags
    document
        .querySelector('[data-filter-type="tag"][data-val="all"]')
        ?.classList.add("active");

    buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
            const filterType = btn.getAttribute("data-filter-type");
            const val = btn.getAttribute("data-val");

            if (!filterType || !val) return;

            // Update active state + aria-pressed for that group
            buttons.forEach((b) => {
                if (b.getAttribute("data-filter-type") === filterType) {
                    b.classList.remove("active");
                    b.setAttribute("aria-pressed", "false");
                }
            });
            btn.classList.add("active");
            btn.setAttribute("aria-pressed", "true");

            // Update state
            if (filterType === "tag") activeTag = val;
            if (filterType === "author") activeAuthor = val;

            // Filter items
            items.forEach((item) => {
                const itemTag = item.getAttribute("data-tag");
                const itemAuthor = item.getAttribute("data-author");

                const matchTag = activeTag === "all" || itemTag === activeTag;
                const matchAuthor =
                    activeAuthor === "all" || itemAuthor === activeAuthor;

                if (matchTag && matchAuthor) {
                    item.style.display = "block";
                } else {
                    item.style.display = "none";
                }
            });
        });
    });
</script>
