---
import MainLayout from "../../layouts/MainLayout.astro";
import { fetchLogs } from "../../lib/directus";

const directusLogs = await fetchLogs();

const fallbackLogs = [
    {
        slug: "fine-tuning-llama-on-my-resume",
        title: "FINE-TUNING LLAMA ON MY RESUME",
        date: "2023.08.05",
        tag: "AI",
        excerpt:
            "An experiment in creating a personal oracle using LoRA fine-tuning.",
    },
    {
        slug: "migrating-to-zfs-pools",
        title: "MIGRATING TO ZFS POOLS",
        date: "2023.10.24",
        tag: "INFRA",
        excerpt:
            "How I survived a double disk failure during my lab migration.",
    },
    {
        slug: "why-pandas-is-slow",
        title: "WHY PANDAS IS SLOW (AND THE FIX)",
        date: "2023.09.12",
        tag: "PYTHON",
        excerpt:
            "Optimizing vectorized operations for large-scale retail datasets.",
    },
];

const logs =
    directusLogs.length > 0
        ? directusLogs.map((l: any) => ({
              slug: l.slug ?? "",
              title: (l.title ?? "UNTITLED").toUpperCase(),
              date: l.published_at
                  ? new Date(l.published_at)
                        .toISOString()
                        .slice(0, 10)
                        .replace(/-/g, ".")
                  : "—",
              tag: (l.tag ?? l.category ?? "").toUpperCase(),
              excerpt: l.excerpt ?? "",
          }))
        : fallbackLogs;

const uniqueTags = [...new Set(logs.map((l: any) => l.tag))].sort();
---

<MainLayout title="DEV LOG // DATA DREAMER">
    <main class="container page-content">
        <header class="page-hero-header">
            <span class="meta-text">// TERMINAL LOGS</span>
            <h1 class="page-title">DEV LOG</h1>
        </header>

        <div class="filter-bar">
            <button class="filter-btn active" data-tag="all">All Logs</button>
            {
                uniqueTags.map((tag) => (
                    <button class="filter-btn" data-tag={tag}>
                        {tag}
                    </button>
                ))
            }
        </div>

        <ul class="log-list">
            {
                logs.map((post: any) => (
                    <li class="log-item" data-tag={post.tag}>
                        <a href={`/logs/${post.slug}`} class="log-link">
                            <div class="log-date">{post.date}</div>
                            <div class="log-title">{post.title}</div>
                            <div class="log-tag">{post.tag}</div>
                        </a>
                    </li>
                ))
            }
        </ul>

        {
            logs.length === 0 && (
                <div class="empty-state">
                    <p class="meta-text" style="color:#999;">
                        // NO LOGS FOUND — SYSTEM IDLE
                    </p>
                </div>
            )
        }
    </main>
</MainLayout>

<style>
    .page-content {
        padding-top: 56px;
    }

    .log-list {
        list-style: none;
        margin-bottom: 100px;
    }

    .filter-bar {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        border-top: 1px solid var(--color-gray);
        border-bottom: 1px solid var(--color-gray);
        padding: 24px 0;
        margin-bottom: 60px;
    }

    .filter-btn {
        background: none;
        border: 1px solid #ccc;
        padding: 6px 16px;
        font-family: var(--font-tech);
        font-size: 10px;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.2s;
        color: #666;
    }

    .filter-btn:hover,
    .filter-btn.active {
        background: var(--color-primary);
        color: white;
        border-color: var(--color-primary);
    }

    .log-item {
        border-bottom: 1px solid var(--color-border);
    }
    .log-link {
        display: flex;
        align-items: center;
        gap: 24px;
        padding: 24px 8px;
        text-decoration: none;
        color: inherit;
        transition:
            background 0.25s ease,
            padding-left 0.25s ease;
    }
    .log-link:hover {
        background: var(--color-primary);
        padding-left: 16px;
    }
    .log-link:hover * {
        color: white;
    }
    .log-link:hover .log-tag {
        border-color: white;
    }
    .log-date {
        width: 110px;
        flex-shrink: 0;
        font-size: 11px;
        color: #999;
    }
    .log-title {
        font-family: var(--font-display);
        font-size: 28px;
        flex-grow: 1;
        line-height: 1;
    }
    .log-tag {
        font-size: 10px;
        border: 1px solid #ccc;
        padding: 3px 8px;
        flex-shrink: 0;
        color: #666;
    }
    .empty-state {
        padding: 80px 0;
        text-align: center;
    }

    @media (prefers-color-scheme: dark) {
        .log-item {
            border-color: #2a2a2a;
        }
        .log-date {
            color: #666;
        }
        .log-tag {
            border-color: #444;
            color: #888;
        }
    }

    @media (max-width: 768px) {
        .log-link {
            flex-wrap: wrap;
            gap: 8px;
            padding: 16px 8px;
        }
        .log-date {
            width: auto;
        }
        .log-title {
            font-size: 20px;
            flex-basis: 100%;
            order: 3;
        }
        .log-tag {
            order: 2;
            margin-left: auto;
        }
    }

    @media (prefers-color-scheme: dark) {
        .filter-btn {
            border-color: #444;
            color: #888;
        }
    }
</style>

<script>
    const buttons = document.querySelectorAll(".filter-btn");
    const items = document.querySelectorAll(
        ".log-item",
    ) as NodeListOf<HTMLElement>;

    buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
            const tag = btn.getAttribute("data-tag");

            // Toggle active state
            buttons.forEach((b) => b.classList.remove("active"));
            btn.classList.add("active");

            // Filter items
            items.forEach((item) => {
                const itemTag = item.getAttribute("data-tag");
                if (tag === "all" || itemTag === tag) {
                    item.style.display = "block";
                } else {
                    item.style.display = "none";
                }
            });
        });
    });
</script>
