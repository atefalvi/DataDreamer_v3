---
import MainLayout from "../layouts/MainLayout.astro";
import HeroCanvas from "../components/hero/HeroCanvas.astro";
import ProjectCard from "../components/projects/ProjectCard.astro";
import {
    fetchFeaturedProjects,
    fetchRecentLogs,
    getAssetUrl,
} from "../lib/directus";

const directusProjects = await fetchFeaturedProjects(3);
const directusLogs = await fetchRecentLogs(3);

// Static fallback projects
const fallbackProjects = [
    {
        title: "PREDICTIVE RETAIL MODEL",
        description:
            "SARIMA time-series forecasting for inventory optimization in multi-channel commerce environments.",
        image: "https://images.unsplash.com/photo-1551288049-bebda4e38f71?q=80&w=800",
        index: "EXP.01",
        year: "2023",
        tags: ["Python", "Statsmodels"],
        href: "#",
    },
    {
        title: "HOMELAB CLUSTER V4",
        description:
            "High-availability Proxmox environment with ZFS storage arrays and automated LXC deployment scripts.",
        image: "https://images.unsplash.com/photo-1558494949-ef526b0042a0?q=80&w=800",
        index: "EXP.02",
        year: "2023",
        tags: ["Proxmox", "DevOps"],
        href: "#",
    },
    {
        title: "SENTIMENT ENGINE",
        description:
            "Real-time NLP pipeline processing social signals using transformer models and Kafka streams.",
        image: "https://images.unsplash.com/photo-1526374965328-7f61d4dc18c5?q=80&w=800",
        index: "EXP.03",
        year: "2023",
        tags: ["AI", "Kafka"],
        href: "#",
    },
];

const fallbackLogs = [
    {
        slug: "fine-tuning-llama-on-my-resume",
        title: "FINE-TUNING LLAMA ON MY RESUME",
        date: "2023.08.05",
        tag: "AI",
    },
    {
        slug: "migrating-to-zfs-pools",
        title: "MIGRATING TO ZFS POOLS",
        date: "2023.10.24",
        tag: "INFRA",
    },
    {
        slug: "why-pandas-is-slow",
        title: "WHY PANDAS IS SLOW (AND THE FIX)",
        date: "2023.09.12",
        tag: "PYTHON",
    },
];

const projects =
    directusProjects.length > 0
        ? directusProjects.map((p: any, i: number) => ({
              title: (p.title ?? "UNTITLED").toUpperCase(),
              description: p.summary ?? "",
              image: p.cover_image
                  ? getAssetUrl(p.cover_image)
                  : fallbackProjects[i % fallbackProjects.length].image,
              index: `EXP.${String(i + 1).padStart(2, "0")}`,
              year: p.published_at
                  ? new Date(p.published_at).getFullYear().toString()
                  : "2023",
              tags: p.tags ?? [],
              href: p.slug ? `/projects/${p.slug}` : "#",
          }))
        : fallbackProjects;

const logs =
    directusLogs.length > 0
        ? directusLogs.map((l: any) => ({
              slug: l.slug ?? "",
              title: (l.title ?? "UNTITLED").toUpperCase(),
              date: l.published_at
                  ? new Date(l.published_at)
                        .toISOString()
                        .slice(0, 10)
                        .replace(/-/g, ".")
                  : "—",
              tag: (l.tag ?? l.category ?? "").toUpperCase(),
          }))
        : fallbackLogs;
---

<MainLayout title="DATA DREAMER // ANALYST">
    <HeroCanvas />

    <!-- Featured Projects Teaser -->
    <section class="container teaser-section">
        <header class="section-header-block">
            <div class="section-header-content">
                <span class="meta-text" style="color:#999;"
                    >// RECENT DEPLOYMENTS</span
                >
                <h2 class="section-title">PROJECTS</h2>
            </div>
            <a href="/projects" class="btn">View All Projects →</a>
        </header>
        <div class="teaser-projects-grid">
            {
                projects.map((project: any) => (
                    <ProjectCard
                        title={project.title}
                        description={project.description}
                        image={project.image}
                        index={project.index}
                        year={project.year}
                        tags={project.tags}
                        href={project.href}
                    />
                ))
            }
        </div>
    </section>

    <!-- Recent Logs Teaser -->
    <section class="container teaser-section">
        <header class="section-header-block">
            <div class="section-header-content">
                <span class="meta-text" style="color:#999;"
                    >// TERMINAL OUTPUT</span
                >
                <h2 class="section-title">DEV LOG</h2>
            </div>
            <a href="/logs" class="btn">View All Logs →</a>
        </header>
        <ul class="teaser-log-list">
            {
                logs.map((post: any) => (
                    <li class="teaser-log-item">
                        <a href={`/logs/${post.slug}`} class="teaser-log-link">
                            <span class="teaser-log-date">{post.date}</span>
                            <span class="teaser-log-title">{post.title}</span>
                            <span class="teaser-log-tag">{post.tag}</span>
                        </a>
                    </li>
                ))
            }
        </ul>
    </section>
</MainLayout>

<style>
    .teaser-section {
        padding-top: 80px;
        padding-bottom: 80px;
        border-top: 1px solid var(--color-border);
    }

    .teaser-projects-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 40px;
    }

    /* ── Log list ── */
    .teaser-log-list {
        list-style: none;
    }

    .teaser-log-item {
        border-bottom: 1px solid var(--color-border);
    }

    .teaser-log-link {
        display: flex;
        align-items: center;
        gap: 24px;
        padding: 24px 8px;
        text-decoration: none;
        color: inherit;
        transition:
            background 0.25s ease,
            padding-left 0.25s ease;
    }

    .teaser-log-link:hover {
        background: var(--color-primary);
        padding-left: 16px;
    }

    .teaser-log-link:hover * {
        color: white;
    }
    .teaser-log-link:hover .teaser-log-tag {
        border-color: white;
    }

    .teaser-log-date {
        width: 110px;
        flex-shrink: 0;
        font-size: 11px;
        color: #999;
    }

    .teaser-log-title {
        font-family: var(--font-display);
        font-size: 28px;
        flex-grow: 1;
        line-height: 1;
    }

    .teaser-log-tag {
        font-size: 10px;
        border: 1px solid #ccc;
        padding: 3px 8px;
        flex-shrink: 0;
        color: #666;
    }

    @media (max-width: 1024px) {
        .teaser-projects-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .teaser-projects-grid {
            grid-template-columns: 1fr;
            gap: 48px;
        }
        .teaser-log-link {
            flex-wrap: wrap;
            gap: 8px;
        }
        .teaser-log-date {
            width: auto;
        }
        .teaser-log-title {
            flex-basis: 100%;
            order: 3;
            font-size: 20px;
        }
        .teaser-log-tag {
            order: 2;
            margin-left: auto;
        }
    }
</style>
