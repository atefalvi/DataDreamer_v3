---
import MainLayout from "../layouts/MainLayout.astro";
import HeroCanvas from "../components/hero/HeroCanvas.astro";
import ProjectCard from "../components/projects/ProjectCard.astro";
import {
    fetchFeaturedProjects,
    fetchRecentLogs,
    getAssetUrl,
} from "../lib/directus";

const directusProjects = await fetchFeaturedProjects(3);
const directusLogs = await fetchRecentLogs(3);

const projects = directusProjects.map((p: any, i: number) => ({
    title: (p.title ?? "UNTITLED").toUpperCase(),
    description: p.summary ?? "",
    image: p.cover_image ? getAssetUrl(p.cover_image) : null,
    index: `EXP.${String(i + 1).padStart(2, "0")}`,
    year: p.published_at ? new Date(p.published_at).getFullYear().toString() : "2024",
    tags: p.tags ?? [],
    href: p.slug ? `/projects/${p.slug}` : "#",
}));

const logs = directusLogs.map((l: any) => ({
    slug: l.slug ?? "",
    title: (l.title ?? "UNTITLED").toUpperCase(),
    date: l.published_at ? new Date(l.published_at).toISOString().slice(0, 10).replace(/-/g, ".") : "—",
    tag: (l.tag ?? l.category ?? "").toUpperCase(),
}));
---

<MainLayout title="DATA DREAMER // ANALYST">
    <HeroCanvas />

    <!-- Featured Projects Teaser -->
    <section class="container teaser-section">
        <header class="section-header-block">
            <div class="section-header-content">
                <span class="meta-text" style="color:var(--text-secondary);"
                    >// RECENT DEPLOYMENTS</span
                >
                <h2 class="section-title">PROJECTS</h2>
            </div>
            <a href="/projects" class="btn">View All Projects →</a>
        </header>
        <div class="teaser-projects-grid">
            {
                projects.map((project: any) => (
                    <ProjectCard
                        title={project.title}
                        description={project.description}
                        image={project.image}
                        index={project.index}
                        year={project.year}
                        tags={project.tags}
                        href={project.href}
                    />
                ))
            }
        </div>
    </section>

    <!-- Recent Logs Teaser -->
    <section class="container teaser-section">
        <header class="section-header-block">
            <div class="section-header-content">
                <span class="meta-text" style="color:var(--text-secondary);"
                    >// TERMINAL OUTPUT</span
                >
                <h2 class="section-title">DEV LOG</h2>
            </div>
            <a href="/logs" class="btn">View All Logs →</a>
        </header>
        <ul class="teaser-log-list">
            {
                logs.map((post: any) => (
                    <li class="teaser-log-item">
                        <a href={`/logs/${post.slug}`} class="teaser-log-link">
                            <span class="teaser-log-date">{post.date}</span>
                            <span class="teaser-log-title">{post.title}</span>
                            <span class="teaser-log-tag">{post.tag}</span>
                        </a>
                    </li>
                ))
            }
        </ul>
    </section>
</MainLayout>

<style>
    .teaser-section {
        padding-top: 80px;
        padding-bottom: 80px;
        border-top: 1px solid var(--color-border);
    }

    .teaser-projects-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 40px;
    }

    /* ── Log list ── */
    .teaser-log-list {
        list-style: none;
    }

    .teaser-log-item {
        border-bottom: 1px solid var(--color-border);
    }

    .teaser-log-link {
        display: flex;
        align-items: center;
        gap: 24px;
        padding: 24px 8px;
        text-decoration: none;
        color: inherit;
        transition:
            background 0.25s ease,
            padding-left 0.25s ease;
    }

    .teaser-log-link:hover {
        background: var(--color-primary);
        padding-left: 16px;
    }

    .teaser-log-link:hover * {
        color: white;
    }
    .teaser-log-link:hover .teaser-log-tag {
        border-color: white;
    }

    .teaser-log-date {
        width: 110px;
        flex-shrink: 0;
        font-size: 11px;
        color: var(--text-secondary);
    }

    .teaser-log-title {
        font-family: var(--font-display);
        font-size: 28px;
        flex-grow: 1;
        line-height: 1;
    }

    .teaser-log-tag {
        font-size: 10px;
        border: 1px solid var(--border);
        padding: 3px 8px;
        flex-shrink: 0;
        color: var(--text-secondary);
    }

    @media (max-width: 1024px) {
        .teaser-projects-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .teaser-projects-grid {
            grid-template-columns: 1fr;
            gap: 48px;
        }
        .teaser-log-link {
            flex-wrap: wrap;
            gap: 8px;
        }
        .teaser-log-date {
            width: auto;
        }
        .teaser-log-title {
            flex-basis: 100%;
            order: 3;
            font-size: 20px;
        }
        .teaser-log-tag {
            order: 2;
            margin-left: auto;
        }
    }
</style>
