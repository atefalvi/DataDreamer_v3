---
/**
 * MainLayout — Global shell with grain overlay, cursor halo canvas,
 * Navigation, Footer, and <slot /> for page content.
 */
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
    title?: string;
    description?: string;
    /** Absolute URL to the OG image (1200×630). If omitted, falls back to /og/default.jpg */
    ogImage?: string;
    /** 'website' for index/about, 'article' for log/project posts */
    ogType?: "website" | "article";
    /** Override canonical URL. Defaults to current request URL. */
    canonical?: string;
}

const SITE_URL = "https://data-dreamer.net";

const {
    title = "DATA DREAMER // ANALYST",
    description = "Analyst, data engineer, and AI builder. Exploring the edge of what machines can dream.",
    ogImage = `${SITE_URL}/og/default.jpg`,
    ogType = "website",
    canonical = new URL(Astro.request.url).href.split("?")[0],
} = Astro.props;

const ogTitle = title;
const ogDescription = description;
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Anton&family=JetBrains+Mono:wght@400;700&display=swap"
            rel="stylesheet"
        />
        <meta name="generator" content={Astro.generator} />

        <!-- Primary -->
        <title>{title}</title>
        <meta name="description" content={ogDescription} />
        <link rel="canonical" href={canonical} />

        <!-- Open Graph -->
        <meta property="og:site_name" content="Data Dreamer" />
        <meta property="og:type" content={ogType} />
        <meta property="og:url" content={canonical} />
        <meta property="og:title" content={ogTitle} />
        <meta property="og:description" content={ogDescription} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />

        <!-- Twitter / X -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={ogTitle} />
        <meta name="twitter:description" content={ogDescription} />
        <meta name="twitter:image" content={ogImage} />

        <!-- Theme init (inline — must run before paint) -->
        <script is:inline>
            (function() {
                const savedTheme = localStorage.getItem('theme');
                const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                if (savedTheme === 'light' || (!savedTheme && !systemPrefersDark)) {
                    document.documentElement.setAttribute('data-theme', 'light');
                } else {
                    document.documentElement.setAttribute('data-theme', 'dark');
                }
            })();
        </script>
    </head>
    <body>
        <!-- Grain texture overlay -->
        <div class="grain-overlay"></div>

        <!-- Global cursor halo canvas -->
        <canvas
            id="cursorCanvas"
            style="position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9998;"
        ></canvas>

        <Navigation />

        <slot />

        <Footer />

        <!-- Image Grid Lightbox -->
        <div class="ig-lightbox" id="igLightbox" role="dialog" aria-modal="true" aria-label="Image viewer">
            <button class="ig-lightbox-close" id="igClose" aria-label="Close">✕</button>
            <button class="ig-lightbox-nav ig-lightbox-prev" id="igPrev" aria-label="Previous">←</button>
            <img class="ig-lightbox-img" id="igImg" src="" alt="" />
            <button class="ig-lightbox-nav ig-lightbox-next" id="igNext" aria-label="Next">→</button>
            <span class="ig-lightbox-counter" id="igCounter"></span>
        </div>
        <script>
            (function () {
                const lb = document.getElementById('igLightbox') as HTMLElement;
                const lbImg = document.getElementById('igImg') as HTMLImageElement;
                const lbCounter = document.getElementById('igCounter') as HTMLElement;

                let items: HTMLElement[] = [];
                let idx = 0;

                function show(i: number) {
                    idx = (i + items.length) % items.length;
                    const src = items[idx].dataset.src ?? '';
                    const alt = items[idx].querySelector('img')?.alt || `Image ${idx + 1} of ${items.length}`;
                    lbImg.alt = alt;   // set alt before src so screen readers announce correctly
                    lbImg.src = src;
                    lbCounter.textContent = `${idx + 1} / ${items.length}`;
                    lbCounter.setAttribute('aria-live', 'polite');
                }

                function open(gridItems: HTMLElement[], i: number) {
                    items = gridItems;
                    show(i);
                    lb.classList.add('active');
                    document.body.style.overflow = 'hidden';
                }

                function close() {
                    lb.classList.remove('active');
                    document.body.style.overflow = '';
                }

                document.getElementById('igClose')?.addEventListener('click', close);
                document.getElementById('igPrev')?.addEventListener('click', () => show(idx - 1));
                document.getElementById('igNext')?.addEventListener('click', () => show(idx + 1));

                lb.addEventListener('click', (e) => { if (e.target === lb) close(); });

                document.addEventListener('keydown', (e) => {
                    if (!lb.classList.contains('active')) return;
                    if (e.key === 'Escape') close();
                    if (e.key === 'ArrowLeft') show(idx - 1);
                    if (e.key === 'ArrowRight') show(idx + 1);
                });

                // Touch swipe
                let tx = 0;
                lb.addEventListener('touchstart', (e) => { tx = e.touches[0].clientX; }, { passive: true });
                lb.addEventListener('touchend', (e) => {
                    const dx = e.changedTouches[0].clientX - tx;
                    if (Math.abs(dx) > 50) dx > 0 ? show(idx - 1) : show(idx + 1);
                });

                function initGrids() {
                    document.querySelectorAll<HTMLElement>('.image-grid').forEach((grid) => {
                        const gridItems = Array.from(grid.querySelectorAll<HTMLElement>('.ig-item'));
                        gridItems.forEach((item, i) => {
                            item.addEventListener('click', () => open(gridItems, i));
                        });
                    });
                }

                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', initGrids);
                } else {
                    initGrids();
                }
            })();
        </script>

        <!-- Global Cursor Trail Script -->
        <script>
            const cursorCanvas = document.getElementById(
                "cursorCanvas",
            ) as HTMLCanvasElement | null;
            if (cursorCanvas) {
                const cCtx = cursorCanvas.getContext("2d")!;
                let cursorW: number;
                let cursorH: number;
                let globalMouse = { x: -999, y: -999 };
                let trail: { x: number; y: number; age: number }[] = [];

                function resizeCursor() {
                    cursorW = cursorCanvas!.width = window.innerWidth;
                    cursorH = cursorCanvas!.height = window.innerHeight;
                }
                resizeCursor();
                window.addEventListener("resize", resizeCursor);

                document.addEventListener("mousemove", (e) => {
                    globalMouse.x = e.clientX;
                    globalMouse.y = e.clientY;
                    trail.push({ x: e.clientX, y: e.clientY, age: 0 });
                    if (trail.length > 18) trail.shift();
                });

                function drawCursor() {
                    cCtx.clearRect(0, 0, cursorW, cursorH);

                    // Soft trail
                    trail.forEach((pt, i) => {
                        pt.age++;
                        const t = i / trail.length;
                        const alpha = t * 0.18;
                        const radius = 2 + t * 10;
                        cCtx.beginPath();
                        cCtx.arc(pt.x, pt.y, radius, 0, Math.PI * 2);
                        cCtx.fillStyle = `rgba(255,46,0,${alpha})`;
                        cCtx.fill();
                    });

                    if (globalMouse.x < 0) {
                        requestAnimationFrame(drawCursor);
                        return;
                    }

                    // Outer glow
                    const grd = cCtx.createRadialGradient(
                        globalMouse.x,
                        globalMouse.y,
                        0,
                        globalMouse.x,
                        globalMouse.y,
                        60,
                    );
                    grd.addColorStop(0, "rgba(255,46,0,0.07)");
                    grd.addColorStop(1, "rgba(255,46,0,0)");
                    cCtx.fillStyle = grd;
                    cCtx.beginPath();
                    cCtx.arc(globalMouse.x, globalMouse.y, 60, 0, Math.PI * 2);
                    cCtx.fill();

                    // Center dot
                    cCtx.beginPath();
                    cCtx.arc(globalMouse.x, globalMouse.y, 3, 0, Math.PI * 2);
                    cCtx.fillStyle = "rgba(255,46,0,0.65)";
                    cCtx.fill();

                    requestAnimationFrame(drawCursor);
                }

                drawCursor();
            }
        </script>
    </body>
</html>
