{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Astro Frontend (dev)",
      "runtimeExecutable": "/opt/homebrew/opt/node/bin/node",
      "runtimeArgs": ["frontend/node_modules/.bin/astro", "dev", "--root", "frontend"],
      "port": 4321
    },
    {
      "name": "Directus Backend (Docker)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "-f", "backend/docker-compose.yml", "up"],
      "port": 8055
    }
  ]
}
